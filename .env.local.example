# YouTube Data API v3 key — used to fetch the 3 latest videos from @YasminShiraz
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# Full URL to Yasmin's Patreon page (e.g. https://www.patreon.com/yasmenshiraz)
PATREON_URL=https://www.patreon.com/your-page-here

# The live domain of this site once deployed — no trailing slash
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com

# MailerLite embedded form ID — found in MailerLite > Forms > Embedded > Form ID
MAILERLITE_FORM_ID=your_form_id_here

# MailerLite API key — found in MailerLite > Integrations > Developer API
MAILERLITE_API_KEY=your_api_key_here
